{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "brewideas",
  "permissions": {
    "reddit": true,
    "http": {
      "enable": true,
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    }
  },
  "post": {
    "dir": "out",
    "entrypoints": {
      "default": {
        "entry": "index.html"
      }
    }
  },
  "dev": {
    "subreddit": "brewideas_dev"
  }
}